# ============================================================
# Docker Compose Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed
# Usage: cp .env.example .env

# ------------------------------------------------------------
# SFTP Configuration
# ------------------------------------------------------------
SFTP_KEYS_DIR=/keys
SFTP_KEY_NAME=sftp_key
SFTP_KEY_TYPE=ed25519
SFTP_KEY_COMMENT=awsglue-sftp-client@devcontainer
SFTP_USER=sftpuser
SFTP_PORT=2222

# ------------------------------------------------------------
# LocalStack Configuration
# ------------------------------------------------------------
DEBUG=0
PERSISTENCE=1
LOCALSTACK_API_KEY=

# ------------------------------------------------------------
# AWS Configuration
# ------------------------------------------------------------
AWS_REGION=us-west-2
AWS_ENDPOINT_URL=http://localstack:4566
AWS_SECRETS_PREFIX=nan-wl-workloads-data-lake-develop

# ------------------------------------------------------------
# Team Tailor Configuration
# ------------------------------------------------------------
TEAMTAILOR_API_TOKEN=your_teamtailor_api_token_here

# ------------------------------------------------------------
# Project Configuration
# ------------------------------------------------------------
PROJECT_NAME=nan
ENVIRONMENT=develop
