# ==========================================
# LOCAL DEVELOPMENT CONFIGURATION EXAMPLE
# ==========================================
# Copy this file to .env and customize for your local development environment
# Most configuration is loaded from AWS Parameter Store via .envrc and Teller

# ==========================================
# REQUIRED VARIABLES
# ==========================================

# Stage: Use 'local' for local development with LocalStack
# This activates LocalStack endpoints and hybrid mode (LocalStack + Real AWS)
STAGE=local

# ==========================================
# OPTIONAL VARIABLES (with defaults)
# ==========================================

# LocalStack Endpoint (optional, defaults to http://localstack:4566)
# Only needed if LocalStack is running on a different endpoint
# LOCALSTACK_ENDPOINT=http://localstack:4566

# AWS Region (optional, defaults to us-east-1 for LocalStack, us-west-2 for real AWS)
# LocalStack works with any region, but us-east-1 is commonly used for local development
# Note: Makefile targets automatically set this to us-east-1 for LocalStack
# AWS_REGION=us-east-1

# Load AWS Config from Parameter Store (optional, defaults to true)
# Set to false to skip loading configuration from AWS Parameter Store via Teller
# Useful for testing without AWS credentials
# LOAD_AWS_CONFIG=true

# ==========================================
# NOTES
# ==========================================
# - Most variables are loaded from AWS Parameter Store via Teller (.teller.yml)
# - See .envrc.example for the complete environment setup with direnv
# - For production environments, variables are loaded from Parameter Store automatically
# - This file only needs minimal local development overrides
#
# Variables automatically configured by .envrc when STAGE=local:
# - AWS_ENDPOINT_URL=http://localstack:4566
# - AWS_ENDPOINT_URL_S3=http://localstack:4566
# - AWS_ENDPOINT_URL_GLUE=http://localstack:4566
# - AWS_PROFILE (derived from AWS_ACCOUNT_NAME)
#
# Variables set by Makefile targets (make pyshell-run, make spark-submit):
# - AWS_REGION=us-east-1
# - AWS_DEFAULT_REGION=us-east-1
# - AWS_ACCESS_KEY_ID=test
# - AWS_SECRET_ACCESS_KEY=test
# - AWS_PROFILE is unset (to avoid conflicts)

# ==========================================
# SFTP CONFIGURATION (for DevContainer services)
# ==========================================
# These variables are used by docker-compose services (sftp-keys-init, sftp-server)
# They are NOT loaded by direnv/Teller - docker-compose reads .env directly

# SFTP Keys Directory (optional, defaults to /keys in init container)
# SFTP_KEYS_DIR=/keys

# SFTP Key Name (required for sftp-keys-init service)
SFTP_KEY_NAME=sftp_key

# SFTP Key Type (required for sftp-keys-init service)
# Options: ed25519 (recommended), rsa, ecdsa
SFTP_KEY_TYPE=ed25519

# SFTP Key Comment (required for sftp-keys-init service)
SFTP_KEY_COMMENT=awsglue-sftp-client

# SFTP User (optional, defaults to sftpuser)
# SFTP_USER=sftpuser

# SFTP Port (optional, defaults to 2222)
# SFTP_PORT=2222
