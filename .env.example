# ============================================================================
# AWS Glue ETL Boilerplate - Environment Variables Example
# ============================================================================
# Copy this file to `.env` and customize for local development.
# All values can be overridden by Glue job arguments (e.g. --SOURCE_NAME public_api).

# Core runtime
STAGE=local
ENVIRONMENT=local
AWS_REGION=us-east-1
LOG_LEVEL=INFO

# LocalStack / local endpoints (optional)
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ENDPOINT_URL_S3=http://localstack:4566
AWS_ENDPOINT_URL_GLUE=http://localstack:4566

# Base job config (shared across layers)
SOURCE_NAME=public_api
JOB_NAME=public_api_pipeline
RAW_ZONE_PATH=s3://example-data-lake/raw-zone/
WAREHOUSE_PATH=s3://example-data-lake/warehouse/

# Medallion databases
RAW_DATABASE_NAME=raw_zone
BRONZE_DATABASE_NAME=bronze_zone
SILVER_DATABASE_NAME=silver_zone
GOLD_DATABASE_NAME=gold_zone

# Public API extraction config (Raw layer)
ENTITY_TYPE=posts
API_BASE_URL=https://jsonplaceholder.typicode.com
API_ENDPOINT=/posts
API_KEY=
RATE_LIMIT_PER_SECOND=5
MAX_RETRIES=3
BATCH_SIZE=500

# Optional AWS credentials for local execution
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
