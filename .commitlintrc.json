{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "subject-max-length": [2, "always", 100],
    "scope-enum": [
      2,
      "always",
      [
        "bronze",
        "silver",
        "gold",
        "utils",
        "libs",
        "config",
        "ci",
        "deps",
        "migrations"
      ]
    ]
  }
}
