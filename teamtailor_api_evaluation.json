    "sample_records": [
      {
        "id": "463287",
        "type": "jobs",
        "links": {
          "careersite-job-url": "https://nanlabs.na.teamtailor.com/en/jobs/463287-analytics-engineer",
          "careersite-job-apply-url": "https://nanlabs.na.teamtailor.com/jobs/463287-analytics-engineer/applications/new",
          "careersite-job-apply-iframe-url": "https://nanlabs.na.teamtailor.com/jobs/463287-analytics-engineer/applications/new?iframe=true",
          "self": "https://api.na.teamtailor.com/v1/jobs/463287"
        },
        "attributes": {
          "apply-button-text": null,
          "body": "<p><strong>Analytics Engineer</strong><br>Remote \u2013 LATAM</p><p><strong>About the Project</strong><br>We\u2019re partnering with a US-based insurtech company that operates as a Managing General Agent (MGA). They specialize in providing homeowners insurance in high-risk wildfire areas in California, leveraging data, predictive models, satellite imagery, and AI to evaluate risks with precision.</p><p>The team\u2019s mission is to enhance compliance processes and data flows, ensuring seamless integration between systems and APIs. It\u2019s a collaborative environment where communication, adaptability, and continuous learning are highly valued.</p><p><strong>What you\u2019ll do</strong></p><ul>\n<li>Design, build, and maintain dashboards in Looker to support business decision-making.</li>\n<li>Build and refine LookML models and Explores to maintain a consistent, trusted semantic layer.</li>\n<li>Build robust SQL and PostGIS queries and datasets that support analytics and backend logic.</li>\n<li>Analyze existing data structures and help guide database improvements toward more structured, scalable models.</li>\n<li>Improve data quality and integrate information from multiple sources to ensure consistency across reports and workflows.</li>\n<li>Produce descriptive analyses and statistics that support business, operational, and risk insights.</li>\n<li>Collaborate closely with product, engineering, and data teams to ensure smooth delivery and clear communication.</li>\n<li>Contribute to a learning-oriented, feedback-driven culture by sharing insights from both backend and data work.</li>\n</ul><p><strong>Tech Stack You\u2019ll Use</strong><strong><strong></strong><br></strong></p><ul>\n<li><strong>BI &amp; Semantic Layer:</strong> Looker, LookML</li>\n<li><strong>Database</strong>: PostgreSQL (Core DB), BigQuery (Analytics)</li>\n<li><strong>Geospatial</strong>: PostGIS</li>\n<li><strong>Languages</strong>: SQL (Advanced), Python (Processing/Automation)</li>\n<li><strong>Cloud</strong>: Google Cloud Platform (GCP)</li>\n</ul><p><strong>Nice to have</strong><strong><br></strong></p><ul>\n<li><strong>Backend-to-Data Background:</strong> Experience transitioning from backend engineering into data work.</li>\n<li><strong>Tech Stack:</strong> Familiarity with NestJS and TypeScript for occasional API or endpoint updates.</li>\n<li><strong>Engineering Collaboration:</strong> Ability to work with backend teams to resolve data issues and improve API data flows.</li>\n<li><strong>ML Awareness:</strong> Basic understanding of ML workflows or model-generated outputs.</li>\n</ul><p><strong>What you\u2019ll get</strong><br></p><ul>\n<li><strong>Time off &amp; well-being:</strong> vacations fully flexible and self-managed, sick leave and personal days, public holidays, paternity and maternity leave, study leave, and moving days.</li>\n<li><strong>Learning &amp; growth:</strong> training in best practices and tech, books and light talks, in-house English classes, continuous feedback, and 1:1 career development sessions.</li>\n<li><strong>Work experience:</strong> flexible working hours, equipment and work materials provided, internal events and team activities, and a day off on your birthday.</li>\n<li><strong>Contract &amp; setup:</strong> 100% remote positions across LATAM, under a contractor model with payment in USD.</li>\n</ul>",
          "end-date": null,
